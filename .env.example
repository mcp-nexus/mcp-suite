# =============================================================================
# mcp-suite — Environment Configuration
# Copy this file to .env and fill in your values.
# Only the domains you configure will be active.
# =============================================================================

# -----------------------------------------------------------------------------
# Authentication
# Required in production mode (AUTH_DISABLED=false).
# Generate a dev token: npx mcp-suite gen-token
# -----------------------------------------------------------------------------
MCP_JWT_SECRET=change-me-to-a-long-random-secret

# Set to true ONLY for local development — skips JWT validation entirely.
AUTH_DISABLED=false

# -----------------------------------------------------------------------------
# Financial Markets Domain (Alpha Vantage + CoinGecko)
# Tools: get_stock_quote, get_forex_rate, get_crypto_price, get_market_news
# Free key: https://www.alphavantage.co/support/#api-key (25 req/day free tier)
# Leave empty to disable this domain at startup.
# -----------------------------------------------------------------------------
ALPHA_VANTAGE_API_KEY=

# -----------------------------------------------------------------------------
# Web3 / DeFi Domain (Alchemy + OpenSea + Blur)
# Tools: get_nft_floor, get_nft_recent_sales, get_wallet_balances,
#        get_amm_reserves, get_dex_liquidity
# Alchemy key: https://dashboard.alchemy.com (free tier available)
# OpenSea key: https://docs.opensea.io/reference/api-keys
# Both keys required to enable this domain.
# -----------------------------------------------------------------------------
ALCHEMY_API_KEY=
OPENSEA_API_KEY=

# -----------------------------------------------------------------------------
# Developer Tools Domain (GitHub)
# Tools: get_repo_stats, summarize_pr, get_pipeline_status, get_deployment_health
# Create a PAT: https://github.com/settings/tokens
# Scopes: public_repo (public repos only) or repo (includes private repos)
# Leave empty to disable this domain at startup.
# -----------------------------------------------------------------------------
GITHUB_TOKEN=

# -----------------------------------------------------------------------------
# Healthcare / FHIR Domain
# Tools: lookup_patient, get_observations, get_medications
# No API key required — defaults to the public HAPI FHIR R4 sandbox.
# WARNING: Only override FHIR_BASE_URL with a HIPAA-compliant endpoint when
# handling real PHI. The default sandbox contains synthetic data only.
# -----------------------------------------------------------------------------
FHIR_BASE_URL=https://hapi.fhir.org/baseR4

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
# Log verbosity: debug | info | warn | error
LOG_LEVEL=info

# Port used when running with --transport http
MCP_PORT=3000
